# Sepolia 테스트넷 배포 시 필요 (로컬 테스트는 불필요)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
PRIVATE_KEY=your_private_key_without_0x_prefix

# ── Oracle Service 설정 ──────────────────────────────────────────
# 병원 데이터 제공자 선택: mock (기본, 테스트용) | hira (실제 HIRA API)
HOSPITAL_PROVIDER=mock

# Oracle 서비스 계정 개인키 (Hardhat Account #3, 로컬 테스트용)
ORACLE_KEY=0x7c852118294e51e653712a81e05800f419141751be58f605c371e15141b007a6

# 로컬 블록체인 RPC
RPC_URL=http://127.0.0.1:8545

# ── HIRA API 설정 (HOSPITAL_PROVIDER=hira 시 필요) ──────────────
# HIRA 개발자 포털: https://www.hira.or.kr/dev
HIRA_API_KEY=발급받은_API_키
HIRA_API_URL=https://apis.data.go.kr/B551182
